{
  "name": "wechat-codex",
  "version": "0.1.0",
  "description": "Bridge WeChat iLink messages to local Codex CLI tasks",
  "type": "module",
  "bin": {
    "wechat-codex": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "qrcode-terminal": "^0.12.0",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
